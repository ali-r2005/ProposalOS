AI_API_KEY=
AI_MODEL=gemini-2.5-flash
NEXT_PUBLIC_API_URL=http://localhost:3000

# Remote Postgres connection string (e.g. Supabase's transaction-mode pooler).
# Required before `npm run db:generate`/`db:migrate` or any proposal persistence works.
# IMPORTANT: if the password contains any of : / ? # [ ] @ ! $ & ' ( ) * + , ; = %
# it MUST be percent-encoded (e.g. via `encodeURIComponent`) or the URL parser
# will silently misread the host/port.
DATABASE_URL=
