{
  "id": "accommodation-showcase",
  "name": "Accommodation Showcase",
  "description": "Photo-collage detail slide, repeated once per selected hotel (repeat over `hotels`).",
  "requiredProps": {
    "option": { "type": "number" },
    "description": { "type": "string" },
    "hotel-url": { "type": "string", "format": "url" },
    "images": {
      "type": "array",
      "items": { "type": "string", "format": "url" }
    },
    "hotel": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "stars": { "type": "array" }
      },
      "required": ["name", "stars"]
    }
  }
}
