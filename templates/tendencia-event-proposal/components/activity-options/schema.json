{
  "id": "activity-options",
  "name": "Activity Options Slide",
  "description": "Summary slide listing the selected activities, one block each (loops over `activities`).",
  "requiredProps": {
    "activities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "category": { "type": "string" }
        },
        "required": ["name", "type", "category"]
      }
    }
  }
}
